# ---------------------------------------------------------------------------
# Configuración del agente. Copia este fichero a `.env` y rellena los valores.
# La API key NUNCA debe subirse al repositorio.
# ---------------------------------------------------------------------------

# --- MiniMax ---------------------------------------------------------------
# Clave de API de tu cuenta MiniMax (obligatoria para llamadas reales).
AGENTE_MINIMAX_API_KEY=

# Endpoint compatible con el estilo OpenAI (chatcompletion_v2).
AGENTE_MINIMAX_BASE_URL=https://api.minimax.io/v1

# Modelo a usar. Lineup actual: MiniMax-M2, MiniMax-M2.5, MiniMax-M2.7.
# (El plan original decía "MiniMax-M3", que no existe.)
AGENTE_MODEL=MiniMax-M2.5

# --- Parámetros del modelo -------------------------------------------------
AGENTE_TEMPERATURE=0.7
AGENTE_MAX_TOKENS=2048

# --- Control del orquestador ----------------------------------------------
# Nº máximo de iteraciones razonar→actuar→observar por tarea.
AGENTE_MAX_STEPS=12
# Timeout por llamada HTTP al modelo (segundos).
AGENTE_REQUEST_TIMEOUT=60
# Reintentos ante errores transitorios de red/API.
AGENTE_MAX_RETRIES=3

# --- Herramientas ----------------------------------------------------------
# Modo "scoped": raíz del sandbox de ficheros. Por defecto "." = el directorio
# de trabajo donde se ejecuta el agente.
AGENTE_FS_ROOT=.
# Nivel de acceso de la herramienta filesystem:
#   scoped -> solo el directorio de trabajo (por defecto)
#   system -> todo el sistema salvo carpetas delicadas (equivale a lanzar con -dap)
AGENTE_FS_ACCESS_MODE=scoped
# Bloquear ficheros de secretos (.env, claves SSH/AWS, *.pem) en ambos modos.
AGENTE_FS_BLOCK_SECRETS=true
# Habilitar la herramienta de búsqueda web.
AGENTE_ENABLE_WEB_SEARCH=true

# --- Observabilidad --------------------------------------------------------
AGENTE_LOG_LEVEL=INFO
# json | console
AGENTE_LOG_FORMAT=console
